{% extends 'themes/default/app/layout/layout.html.twig' %}

{% block meta_description %}{% endblock %}
{% block meta_keywords %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('default_homepage') }}
{% endblock %}

{% block title %}Shanbo Budget - gestion de son budget{% endblock %}

{% block main_content %}
    <header>
        <div class="header-infos">
            <div class="header-title" data-aos="fade-right">
                <div class="subtitle">Gestion de son budget</div>
                <div class="title">
                    <h1>Shanbo budget</h1>
                </div>
                <div class="content">
                    <p>
                        Gère ton budget facilement. Prévois tes dépenses, tes économies et tes rentrées d'argents !
                    </p>
                    <div>
                        <a class="btn btn-danger" href="{{ path('app_login') }}"><span>Espace membre</span></a>
                    </div>
                </div>
            </div>
            <div class="header-scroll" data-aos="fade-up">
                <a href="#gardons-contact">
                    <span class="icon-down-arrow"></span>
                    <span>Gardons contact</span>
                </a>
            </div>
        </div>
        <div class="header-drawing">
            <div class="image">
                <img src="{{ asset(path_images ~ "bg.jpg") }}" alt="Illustration Shanbo Budget">
            </div>
        </div>
    </header>

    <section id="gardons-contact">
        <h2 data-aos="fade-right">Gardons contact !</h2>
        <div class="content">
            <div class="social" data-aos="fade-up">
                <p>
                    N'hésites pas à me contacter à travers mon compte Instagram ou mon compte LinkedIn !
                    Que ce soit pour discuter d'un projet, d'échanger des informations en programmation web,
                    de parler de technologies ou tout simplement discuter.
                </p>
                <div class="social-links">
                    <a target="_blank" rel="nofollow" href="https://www.instagram.com/shanbo_daltonien/" title="@shanbo_daltonien">
                        <span class="icon-instagram"></span> Instagram
                    </a>
                    <a target="_blank" rel="nofollow" href="https://www.linkedin.com/in/chanbora-chhun-00a0a0112/" title="LinkedIn de Chanbora Chhun">
                        <span class="icon-linkedin"></span> LinkedIn
                    </a>
                    <a target="_blank" rel="nofollow" href="https://github.com/starozytny" title="Github de Chanbora Chhun alias Starozytny">
                        <span class="icon-github"></span> GitHub
                    </a>
                </div>
            </div>
            <div class="newsletter" data-aos="fade-up">
                <a class="btn btn-primary" target="_blank" href="https://chanbora-chhun.fr"><span>Rester informé</span></a>
            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('default_homepage') }}
{% endblock %}